# Server-side env vars for the key vault.
# In Netlify: set these under Site settings → Environment variables.
# For local dev: copy this file to `.env.local` (which is gitignored).

# Admin passcode that lets the API key modal pull keys from the server vault.
# After 10 wrong attempts in an hour, the endpoint locks for an hour.
ADMIN_PASSCODE=

# Optional: seed the vault with an Anthropic key on first read.
# Once any key has been written to the vault this is ignored.
SEED_ANTHROPIC_KEY=
